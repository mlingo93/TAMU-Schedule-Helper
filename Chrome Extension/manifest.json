{
  "manifest_version": 3,
  "name": "TAMU Term Selector",
  "version": "1.0",
  "description": "Fetches available terms from TAMU College Scheduler",
  "permissions": [
    "cookies",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://tamu.collegescheduler.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png"
    }
  },
  "icons": {
    "16": "icon16.png"
  }
}